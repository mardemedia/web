<div
  id="bubble-container"
  class="absolute inset-0 pointer-events-none overflow-hidden"
>
</div>
<script>
  import random from "./../../utils/random";

  export function spawnBubble(root: HTMLElement | Element) {
    const bubble = document.createElement("bubble-svg");

    const size = random(40, 90);
    const x = random(0, Math.max(0, root.clientWidth - size));
    const duration = random(5000, 10000);
    const opacity = random(0.3, 0.6);

    const color = "teal";

    bubble.setAttribute("r", (size / 2).toString());
    bubble.setAttribute("color", color);
    bubble.style.position = "absolute";
    bubble.style.left = `${x}px`;
    bubble.style.bottom = "-200px";
    bubble.style.opacity = opacity.toString();
    bubble.style.pointerEvents = "none";

    root.appendChild(bubble);

    bubble.animate(
      [
        { transform: "translateY(0) translateX(0)", opacity },
        {
          transform: `translateY(-${root.clientHeight + 200}px) translateX(${random(-50, 50)}px)`,
          opacity: 0,
        },
      ],
      { duration, easing: "ease-out" },
    );

    setTimeout(() => bubble.remove(), duration);
  }

  export default function startBubbleLoop(root: HTMLElement | Element) {
    if (root instanceof HTMLElement) {
      if (getComputedStyle(root).position === "static") {
        root.style.position = "relative";
      }
      root.style.overflow = "hidden";
    }

    setInterval(() => spawnBubble(root), random(600, 1000));
  }

  const $container = document.getElementById("bubble-container")!;
  startBubbleLoop($container);
</script>
